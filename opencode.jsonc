{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "servers": {
      "enabled": true,
      "type": "local",
      "command": "py",
      "args": ["main.py"],
      "cwd": "${workspaceFolder}/mcp-server",
      "kaistu-memories": {
        "enabled": true,
        "type": "local",
        "command": "py",
        "args": ["main.py"],
        "cwd": "D:/kaistu/projects/kaistu-memories"
      }
    },
    "memory": {
      "enabled": true,
      "type": "local"
    }
  }
}