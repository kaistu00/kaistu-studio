{
  "name": "@kaistu/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@kaistu/shared": "*",
    "@tanstack/react-query": "^5.62.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "material-symbols": "^0.45.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "build": {
    "appId": "com.kaistu.studio",
    "productName": "KAISTU Studio",
    "directories": { "output": "release" },
    "files": ["out/**/*"],
    "win": { "icon": "assets/icon.png" },
    "mac": { "icon": "assets/icon.png" },
    "linux": { "icon": "assets/icon.png" }
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.2.0",
    "electron-vite": "^2.3.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  }
}
